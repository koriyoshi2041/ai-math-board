{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/Notebook Board.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(jsx|js|css|html|woff2|woff|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ]
}
