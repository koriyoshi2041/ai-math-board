// chapters/ch2_matrix.js
// 第 2 章 · 方程求解与矩阵 — 完整学习数据(认知科学驱动)
// 覆盖: 向量与范数 / 线性空间 / Ax=b / 条件数 / LU / 正交矩阵 / 投影 / Sherman-Morrison / 特殊矩阵

window.CONTENT_CH2 = {
  overview: {
    one_liner: '矩阵不是冷冰冰的数表,而是「空间里的运动」;向量是被运动的「对象」;解 Ax=b 就是在这场运动留下的四个房间里寻找钥匙。',
    why: [
      '本章是整门课的「线性代数底座」。后面要讲的优化、SVD、PCA、稀疏表示、神经网络反向传播,本质都在这套语言里跳舞。',
      '更具体地说: 你以后做「最小二乘」要用到「投影到列空间」(2.6 节);做「岭回归 / Tikhonov」要用到「Gram 矩阵 + 伪逆」(2.0~2.1);做「BFGS / 在线学习」要用到「Sherman–Morrison」(2.5);做「FFT / 傅里叶」要用到「正交矩阵 + 置换矩阵的特征值」(2.3 习题);做「马尔可夫链 + MCMC」要用到「特征值的乘方稳态」(2.3 习题);做「条件数诊断」要用到本章的 κ(A) 和 Hager 算法(2.3)。',
      '这一切的源头是同一句话: 向量 = 对象,矩阵 = 运动。范数告诉你运动放大了多少,子空间告诉你运动把对象塞进哪个房间,条件数告诉你噪声被放大了多少,分解告诉你这场运动可以拆成哪几段简单的小动作。',
      '所以,这章看似在讲「线性代数」,实际上是在给你一副「能在 AI 系统里看见结构」的眼镜。',
    ].join(' '),
    prereq: [
      '高中向量、矩阵乘法、行列式、初等行变换',
      '基本的二次型 xᵀAx 与对称矩阵',
      '一点点微积分(求 ∂/∂x 用到第 2 章的求导公式)',
      '一点点物理直觉(旋转 / 投影 / 反射 / 缩放都是物理动作)',
    ],
    big_ideas: [
      '【范数家族】L0/L1/L2/L∞/Lp/F/谱/核 都是给「大小」打分的不同口味——选哪种,取决于你对「理想解」的偏好(稀疏?平滑?低秩?)。',
      '【四大基本子空间】行空间 / 列空间 / 零空间 / 左零空间——四个房间的维数 (r, n−r, r, m−r) 完整刻画一个 m×n 矩阵的「能力」。',
      '【秩-零度定理】rank(A) + nullity(A) = n: 一个矩阵「能压扁多少维」+ 「能展开多少维」 = 输入维数。',
      '【Ax=b 的三种命运】rank(A) vs rank([A|b]) vs n 一比就知道是无解、唯一解还是无穷解,这是「二维两条直线」直觉的代数化。',
      '【条件数 κ(A)】= ‖A‖·‖A⁻¹‖ 是把右端项扰动放大成解扰动的「放大倍数」。κ 大叫病态,数值解不可信。',
      '【LU / LDLᵀ / Cholesky】= 一次性「把消元过程记账」,后续无数 b 都只要 O(n²)。',
      '【正交矩阵】QᵀQ=I 同时给你 Q⁻¹=Qᵀ、保长度、保角度、保内积——四件礼物——是数值线性代数的「上帝礼物」。',
      '【投影 P=UUᵀ】= 「找子空间里离你最近的点」的几何解,正是最小二乘和 PCA 的灵魂。',
      '【Sherman–Morrison–Woodbury】= 秩 1(秩 k)校正下,O(n³) 求逆变 O(n²)——BFGS、卡尔曼滤波、在线学习都是它在背后撑场。',
      '【特殊矩阵图谱】置换 / 傅里叶 / 小波 / 马尔可夫——这些「形怪状奇」的矩阵,本质都活在「正交 + 单位根 + 特征值」的同一个家族里。',
    ],
  },
  mindmap: {
    tree: {
      label: '第 2 章 · 方程求解与矩阵',
      detail: '当你说「学线性代数」时,99% 的人想到「算矩阵」。但本章要带你去到的地方是「看矩阵」: 每个矩阵其实是一种空间里的运动,而每个解方程的故事,都是在四个隐形房间里寻找出口。这种视角是高中数学没教你的,也是 AI 数学一切高级技巧的祖宗。',
      children: [
        {
          label: '范数家族',
          detail: '问一个朴素问题: 一根向量「有多大」? 听起来简单,但其实没有标准答案——L1 用脚步数(曼哈顿地铁),L2 用直线距离(鸟飞),L∞ 用最长那一截。**选哪把尺子,等于选你心里希望的「理想解」长什么样**。这就是为什么稀疏建模偏 L1、平滑建模偏 L2、鲁棒控制偏 L∞——尺子塑造结果。',
          children: [
            { label:'向量范数 (L0/L1/L2/L∞/Lp)', detail:'想象 5 把不同形状的「单位球」: L1 是菱形(顶点在坐标轴上,所以 L1 偏好稀疏)、L2 是圆(各向同性,最像物理直觉)、L∞ 是方形(角钝顶平,控最大值)。$p$ 是从 1 到 ∞ 的连续旋钮,p 越大球越方。**球的形状决定了优化解的偏好**。' },
            { label:'加权与 H-诱导内积', detail:'如果某些维度更重要呢? 给它加个权重,等于把空间按比例「捏」一下再量。当权重矩阵 $W$ 推广到对称正定 $H$,内积就变成 $\\langle x, y\\rangle_H = x^T H y$——这是共轭梯度法、自然梯度、Mahalanobis 距离的源头。' },
            { label:'矩阵范数 · 诱导', detail:'矩阵 A 作用在单位圆上变成椭圆。**椭圆最长半轴的长度 = $\\|A\\|_2$**(谱范数)。这把「矩阵的大小」翻译成「最大拉伸倍数」,直觉立刻具象。L1 范数对应「最大列和」、L∞ 对应「最大行和」,记忆口诀「1 列 ∞ 行 2 谱」。' },
            { label:'矩阵范数 · 非诱导', detail:'F 范数把矩阵「拆零件」当向量数,直接 $\\sqrt{\\sum a_{ij}^2}$。核范数 $\\sum\\sigma_i$ 是奇异值的 L1——所以核范数偏好「奇异值稀疏」即「低秩」。**这就是 RPCA、Netflix Prize、矩阵补全的灵魂武器**。' },
            { label:'Cauchy-Schwarz / Hölder', detail:'内积「不能比两边长度的乘积大」——这条朴素事实(C-S 不等式)是后续概率论方差界、KL 散度有界、优化收敛率的祖父定理。Hölder 是 C-S 在不同 p 范数下的兄弟版,$1/p + 1/q = 1$ 这个共轭关系贯穿凸分析。' },
          ],
        },
        {
          label: '线性空间与子空间',
          detail: '「向量空间」听起来高深,其实就是一句话: **任何能加减、能数乘的对象集合,都叫向量空间**——多项式、矩阵、信号、概率分布全是。这种推广让线性代数突然能处理远超「箭头」的对象。子空间是其中「过原点的平直部分」,是矩阵分析的实际舞台。',
          children: [
            { label:'生成 / 线性无关 / 基 / 维', detail:'基就像描述一间屋子的「最少坐标轴」: 既能撑满整间屋(生成),又没有冗余轴(线性无关)。维数 = 轴的根数。同一间屋可以有无数组基,但根数永远一样——这件事乍听像废话,证明起来却是抽象代数第一关。' },
            { label:'子空间的和与直和 ⊕', detail:'两个子空间的「和」是它们能凑出来的所有向量。如果两者除了原点没有交集,这个和叫「直和」 $U \\oplus W$,**意味着每个元素的拆解唯一**——「水平 + 垂直」分解一个二维点就是最熟悉的例子。这种唯一性是后面正交分解的命脉。' },
            { label:'四大基本子空间', detail:'你以为矩阵就是一堆数,但 Strang 揭示: **每个 m×n 矩阵都暗藏 4 个子空间**——列空间、零空间、行空间、左零空间。它们的维数是 $r, n-r, r, m-r$,左右两边各自正交。理解这 4 个房间,你就能一眼看出 Ax=b 有几个解、长什么样。这是从「算矩阵」到「看矩阵」的关键跨越,后面 SVD、PCA 全靠这个直觉。' },
            { label:'秩-零度定理与作业题', detail:'$r + (n-r) = n$——「能输出多少维」+「被压扁多少维」=「输入有多少维」。这是宇宙级的守恒定律,直觉如能量守恒。每次计算秩、零度、维数,都在用它。一旦记住,作业里所有「问 4 个空间维数」的题都是 5 秒内秒杀。' },
          ],
        },
        {
          label: 'Ax=b 求解',
          detail: '高中你解过 $y=3x+4$ 和 $y=5x+2$ 的交点,但你大概没意识到——那其实是本章的「Ax=b」。把这个问题推广到 100 维、有噪声、可能无解、可能多解,就长出了线性回归、控制反馈、PDE 离散化、神经网络反向传播。**所以 Ax=b 不是「数学题」,是 AI 数学的中央车站**,后面所有方法都从这里发车。',
          children: [
            { label:'解的三种命运', detail:'两条直线相交、平行、重合——对应唯一解、无解、无穷解。代数化判别就是 $\\text{rank}(A)$ 和 $\\text{rank}([A|b])$ 比大小。这条规则把高中的几何直觉翻译成了能处理任意维度的代数判据。' },
            { label:'高斯消元 + 部分选主元', detail:'消元就是把「方程减方程」直到只剩简单形式——这是初中就会的事。但「不选主元」会出大事: 一个小主元让舍入误差被放大千倍。**部分选主元 = 每步换最大那行上来**,简单但救命。LAPACK 的工业标准。' },
            { label:'欠定 / 超定 / 最小二乘', detail:'真实数据很少是「方阵」: 100 个测量、2 个未知量(超定),或 10 个测量、100 个未知量(欠定)。超定通常无解,改求 $\\min \\|Ax-b\\|^2$ 得正规方程;欠定有无穷解,加正则才能挑出唯一一个。**这两种情况覆盖了绝大多数真实 AI 任务**。' },
            { label:'伪逆 + Tikhonov', detail:'当 A 不可逆,「广义逆」 $A^+$ 顶上来。伪逆有两种极限定义,$\\lim (A^TA + \\lambda I)^{-1}A^T$ 和 $\\lim A^T(AA^T + \\lambda I)^{-1}$,分别适合高瘦和扁平矩阵。**这就是 Tikhonov 正则化,也是岭回归的代数本质**。后面贝叶斯章会发现它等于「高斯先验下的 MAP」。' },
            { label:'迭代法初步', detail:'矩阵规模大到 $10^9$ 时,直接法走不动。**Jacobi/GS/SOR 像「邻居协商」**——每个分量参考邻居更新一次,反复迭代逼近真解。共轭梯度更聪明: 沿一组「相互 A-正交方向」前进,理论上 $n$ 步就到。这是大规模 AI 优化的入门票。' },
          ],
        },
        {
          label: '矩阵分解',
          detail: '「分解」听起来很学术,其实就是一句话: **把一个复杂运动拆成几段简单运动的复合**——就像把舞步拆成「转身→侧步→定点」。LU 是消元的记账本、Cholesky 是对称版优化、QR 是正交化、SVD 是终极的「旋转-缩放-旋转」三步舞。一旦分解,所有后续操作都变便宜。',
          children: [
            { label:'LU 分解', detail:'高斯消元一旦做完,就把「消元工作」永久记进 L 和 U——下次来个新的 b,只要前向后向两步($O(n^2)$),不用重做整套消元($O(n^3)$)。**这就是「一次投资,反复使用」**。工程上 99% 的解线性方程都长这样。' },
            { label:'LDLᵀ / Cholesky', detail:'对称矩阵享受「五折优惠」: $A = LDL^T$ 比 LU 省一半;对称正定再升级到 $A = LL^T$(Cholesky)。AI 里大多数有意义的矩阵——协方差、Gram、凸函数 Hessian——都是对称正定,所以 Cholesky 是高频武器。' },
            { label:'部分选主元 PA=LU', detail:'数值稳定性的「护身符」。先用置换矩阵 P 把行序排好,再 LU。一个小动作,数值精度立刻好几个数量级。所有靠谱的实现(MATLAB/NumPy/LAPACK)都默认带选主元。' },
            { label:'Sherman–Morrison–Woodbury', detail:'矩阵被「轻微改动」(秩 1 或秩 k 校正)时,**不用重新分解,只用 $O(n^2)$ 修正一下逆**。BFGS 拟牛顿法、卡尔曼滤波、在线学习都靠它——你能想到的所有「增量更新」场景,这条公式都在背后撑场。' },
          ],
        },
        {
          label: '条件数与稳定性',
          detail: '同一段算法,在「好矩阵」上跑得稳,在「病态矩阵」上跑得飞。**$\\kappa(A)$ 量化这个「好坏」**。如果你不知道这个数,就是在闭眼开车——你写的代码可能数学上完美,数值上灾难。本节最重要的事是建立一个职业本能: 看到 Ax=b,先想 $\\kappa(A)$。',
          children: [
            { label:'残差 vs 误差', detail:'最坑爹的事: 残差小不代表误差小。$\\|b - A\\hat{x}\\|$ 看起来好,但 $\\|x - \\hat{x}\\|$ 可能大得吓人——病态矩阵让你「考试分数高,人却不会做题」。**这是初学者最常踩的坑**,后面所有数值经验都从这个反例长出来。' },
            { label:'$\\kappa(A) = \\|A\\|\\cdot\\|A^{-1}\\|$', detail:'$\\kappa = 10^k$ 意味着「输入扰动被放大 $10^k$ 倍」——你丢失了大约 $k$ 位精度。几何上 $\\kappa$ 等于椭圆的「最长半轴 / 最短半轴」之比,所以「又长又扁」的橡皮膜变形最危险——某个方向几乎被压扁,小扰动就翻天覆地。' },
            { label:'Hager 算法估 $\\kappa$', detail:'真正算 $\\|A^{-1}\\|$ 要 $O(n^3)$,工程上不能接受。**Hager 用「子梯度爬坡」$O(n^2)$ 给出量级正确的估计**——LAPACK 的 DGECON 就是它。这是「我虽然不要精确答案,但要快速知道是否危险」的工程智慧典范。' },
            { label:'预条件子 + 缩放', detail:'$\\kappa$ 太大怎么办? 治病三招: 无量纲化(把不同单位拉齐)、缩放(对角矩阵左右乘)、预条件子($M \\approx A^{-1}$ 让 $MA$ 的 $\\kappa$ 变小)。物理工程界的经验法则: 把变量都改成无单位的相对量,$\\kappa$ 立刻好几个量级。' },
          ],
        },
        {
          label: '正交矩阵 + 投影',
          detail: '正交矩阵是「上帝赐礼」: 长度不变、角度不变、内积不变、求逆免费、条件数永远是 1。所以数值线性代数喜欢一切正交的东西——QR、SVD、FFT、小波、Householder。**投影则是几何上「找最近点」的算子**,正是最小二乘的灵魂。掌握这一组,你看 PCA、压缩、几何机器学习都自带几何感。',
          children: [
            { label:'正交矩阵的四件礼物', detail:'$Q^T Q = I$ 这一条公理同时给你 4 件好处: $Q^{-1} = Q^T$(免费求逆)、保 L2 长度、保内积(等价于保角度)、$\\kappa = 1$(数值最稳定)。这就是 QR 分解、Householder 反射、Givens 旋转都被工程界宠爱的根本原因。' },
            { label:'置换矩阵', detail:'每行每列恰一个 1——置换矩阵 = 「换座位」。它是最简单的正交矩阵,$P^T P = I$,$P^{-1} = P^T$。**惊喜**: 它的特征向量恰好是傅里叶矩阵的列,特征值是单位根 $e^{2\\pi i k/n}$。这把第 1 章的 DFT 和本章的特征值彻底打通。' },
            { label:'投影矩阵 P=UUᵀ', detail:'你站在屋里,头顶有一面墙(子空间)——「头顶离墙最近的点」就是投影。当墙的「正交基」是 $U$ 的列,投影矩阵就是 $UU^T$。**幂等性 $P^2 = P$**(投影两次等于一次)是它的指纹。这是 PCA、最小二乘、滤波、压缩的共同骨架。' },
            { label:'最小二乘 = 投影', detail:'$\\min \\|Ax-b\\|^2$ 看起来是优化,其实是几何: **把 b 投影到列空间 $C(A)$ 上,再在 A 里反查那个 x**。这个「优化 ↔ 几何」的对偶视角让你瞬间理解为什么正规方程是 $A^T A x = A^T b$——因为残差必须正交于列空间。' },
          ],
        },
        {
          label: '特殊矩阵图谱',
          detail: '工程里反复出现的「形怪状奇」矩阵——傅里叶、小波、马尔可夫、置换、三对角——其实都活在同一个家族里: **正交 + 单位根 + 特征值分解**。看清这一点,你就明白 FFT、PCA、MCMC 看起来很不同,但代数底座是同一套。这种「统一感」就是数学的优雅所在。',
          children: [
            { label:'4 点傅里叶矩阵 F', detail:'F 的列恰好是循环置换矩阵 P 的特征向量——所以 P 在 F 基下变成对角矩阵,这就是「循环卷积 = DFT 域逐点乘」的代数解释。**这把第 1 章的卷积定理和本章的特征分解两件事融成了一件事**,惊艳。FFT 工程化就是利用这个特征基的快速分解。' },
            { label:'4×4 小波矩阵 W', detail:'W 只有 1, −1, 0 三种元素,每列代表不同尺度的「均值/差分」基——「整体平均」「左右差」「左半细节」「右半细节」。**这是「多尺度分析」的玩具版**,是 JPEG 2000 压缩、医学图像去噪、信号瞬态检测的祖宗。简单到能徒手算,深刻到能撑起一整门工程。' },
            { label:'马尔可夫矩阵 + A^∞', detail:'列和为 1、元素非负——最大特征值恒为 1(Perron-Frobenius)。$A^\\infty$ 的列复制成稳态分布,无论你从哪个初始状态出发,长时间后都到达这个分布。**这就是 MCMC 收敛的代数根**: 想从复杂分布采样,设计一个 A 让它的稳态恰好是该分布,然后跑很多步。' },
            { label:'三对角 / 对称带状', detail:'三对角矩阵 LU 分解只要 $O(n)$——线性时间,因为每行消元只影响下一行。**这是 Thomas 算法的核心**,数值 PDE、谱方法、压缩感知里反复出现。带状结构等于「局部依赖」,等于「计算便宜」,记住这个等式。' },
          ],
        },
        {
          label: 'AI 中的应用',
          detail: '本章不是为了考线代,是为了让你下一次打开 AI 论文时,看到那些「神奇公式」能立刻识别它们的本质。线性回归 = 投影,BFGS = 秩 2 校正,神经网络 = 线性映射 + 非线性激活的复合,Transformer 的 attention = 三个矩阵相乘 + softmax。**所有 AI 算法的最深处,都是矩阵在跳舞**。',
          children: [
            { label:'线性回归 → 伪逆', detail:'回归 $\\min \\|Dw - y\\|^2$ 的闭式解 $w^* = (D^T D)^{-1} D^T y = D^+ y$。**伪逆 = 投影 + 反查**,几何上把 y 压到 D 的列空间,再追问「在 w 空间里这对应哪个 w」。这是后面所有「监督学习」的最简版本。' },
            { label:'PCA / SVD 入门', detail:'PCA 找「方差最大的方向」=「数据矩阵的最大奇异向量」。**SVD 是本章思想的高潮**: 把任意矩阵分解成「旋转-缩放-旋转」三步舞,统一了 LU、QR、Cholesky、特征分解的所有视角。留到后面专章细讲,但先在这里埋下种子: 它是降维、压缩、推荐系统的共同祖先。' },
            { label:'BFGS = Sherman-Morrison', detail:'拟牛顿法的痛点是 Hessian 难算。BFGS 的妙招: **维护一个近似 $H^{-1}$,每步用秩 2 校正更新**——正是 SMW 公式的应用。每步 $O(n^2)$,全程不算 Hessian。这是 PyTorch L-BFGS、SciPy 优化器背后的算法,工业标杆。' },
            { label:'神经网络正向 = 一串运动', detail:'第 $k+1$ 层 $\\mathbf{x}_{k+1} = \\varphi(W_k \\mathbf{x}_k + \\mathbf{b}_k)$ 不就是「矩阵运动 + 非线性扭一下」吗? **整个深度网络 = 这种「矩阵运动 + 扭」的复合**。反向传播 = 沿运动逆向把梯度「拉回去」,用的是转置矩阵 $W_k^T$。这一刻你应该感到豁然开朗。' },
            { label:'图像几何变换 + 齐次坐标', detail:'平移不是线性变换(违反 $f(0)=0$),怎么办? **加一维变成齐次坐标,平移瞬间变成线性**——计算机视觉、机器人学、图形学三件套的语言基础。所有相机标定、SfM、SLAM 都靠它。' },
          ],
        },
      ],
    },
  },
  articles: {

    intro: {
      title: '为什么矩阵不是冷冰冰的数表? —— 一场关于「运动」的线性代数寻路',
      kicker: 'CHAPTER 02 INTRO · 25 min read',
      body: [
        ['h2','一个故事开场: 你在地铁里弄丢了钥匙'],
        ['p','想象你在北京的地铁里弄丢了钥匙。你只记得从家门口到现在,大概走了「向北 3 站、再向东 2 站、又坐了一段反向 1 站」。如果有人问你「钥匙到底在哪?」,你会怎么回答? 你会说: 「在北 2、东 2 那个位置。」'],
        ['p','停一下,品一品这件事。你刚才其实做了三件事:'],
        ['ol', [
          '把「位置」想象成一个**向量**: $(x, y)$ 表示南北和东西。',
          '把每一段地铁路程想象成一种**运动**: 「向北 3 站」这件事,不管你站在哪儿,都是把当前坐标加上 $(0, 3)$。',
          '把整段路程算成「初始位置 + 运动总和」: $\\\\mathbf{p}_{end} = \\\\mathbf{p}_{0} + \\\\mathbf{m}_{1} + \\\\mathbf{m}_{2} + \\\\mathbf{m}_{3}$。',
        ]],
        ['p','**这就是线性代数的全部秘密的雏形**。向量是空间里的「对象」,矩阵是空间里的「运动」,而运动可以叠加、可以拆解、可以被衡量。本章学的所有东西——范数、子空间、Ax=b、条件数、LU、正交、投影、Sherman-Morrison——都只是这一个雏形被反复打磨、放大、用来解决越来越复杂问题的不同侧面。'],
        ['callout','口诀: **向量 = 对象,矩阵 = 运动**。把这两句话刻在心里,本章后面的每一个「定义」「定理」都只是在回答同一个问题: 「我对一个对象做了某种运动,结果如何? 怎么算最快? 怎么算最稳?」'],

        ['h2','为什么本章在 AI 数学里是「底座」?'],
        ['p','你也许会问: 「我学 AI,关心的是神经网络、Transformer、扩散模型,你给我讲矩阵分解干嘛?」答案不是因为「这些是基础所以你要忍着学」,而是: **AI 系统每一层最深处的运算,本质都是「向量被矩阵作用」**。'],
        ['ul', [
          '神经网络第 $k+1$ 层的激活: $\\\\mathbf{x}_{k+1} = \\\\varphi(W_k \\\\mathbf{x}_k + \\\\mathbf{b}_k)$ —— 矩阵 $W_k$ 在「运动」向量 $\\\\mathbf{x}_k$。',
          '反向传播一层梯度: $\\\\delta_k = (W_k^T \\\\delta_{k+1}) \\\\odot \\\\varphi\'(\\\\cdot)$ —— 转置矩阵 $W_k^T$ 在沿反方向「拉回」误差。',
          '线性回归求权重: $\\\\mathbf{w} = (D^T D)^{-1} D^T \\\\mathbf{y}$ —— 这就是本章末要讲的「伪逆 + 投影」。',
          'Adam 优化器: 维护一阶矩 $m$、二阶矩 $v$,本质上是在做「指数加权平均」的向量更新。',
          'Transformer 中的 self-attention: $\\\\text{softmax}(QK^T/\\\\sqrt{d}) V$ —— 三个矩阵相乘 + 一个 softmax。',
        ]],
        ['p','所以,如果你不能在大脑里「看见」一个矩阵在做什么(把空间拉伸了多少倍? 把哪些方向压扁了? 保留了哪些方向的长度?),你就只能在符号上滑行,永远进不了 AI 的「结构层」。'],
        ['quote','"线性代数的几何在三维以下,是看;三维以上,是想。" —— Gilbert Strang《Introduction to Linear Algebra》'],

        ['h2','本章的「故事弧」: 从两条直线相交开始'],
        ['p','整个第 2 章其实是在围绕一个看似简单的问题展开:'],
        ['formula','\\\\text{解 } A\\\\mathbf{x} = \\\\mathbf{b}'],
        ['p','你在初中就会解二元一次方程组——比如 $y = 3x + 4$ 和 $y = 5x + 2$ 的交点。把它写成矩阵形式: $A = \\\\begin{pmatrix} -3 & 1 \\\\\\\\ -5 & 1 \\\\end{pmatrix}, \\\\mathbf{b} = \\\\begin{pmatrix} 4 \\\\\\\\ 2 \\\\end{pmatrix}$,求 $\\\\mathbf{x} = (x, y)^T$。这就是作业第 4 题。'],
        ['p','**那为什么我们要折腾这么久来讲「Ax=b」**? 因为同一个公式背后,藏着五种截然不同的命运:'],
        ['ol', [
          '**唯一解**: 两条直线交于一点。$A$ 满秩,$\\\\det A \\\\neq 0$,$\\\\mathbf{x} = A^{-1}\\\\mathbf{b}$。 (这是初中数学。)',
          '**无穷解**: 两条直线重合。$\\\\text{rank}(A) = \\\\text{rank}([A|\\\\mathbf{b}]) < n$。 (这是高中数学,也是「自由度」概念的源头。)',
          '**无解**: 两条直线平行。$\\\\text{rank}(A) < \\\\text{rank}([A|\\\\mathbf{b}])$。 (这一步开始,你需要的不是「精确解」而是「最佳近似解」。)',
          '**超定有噪声**: 100 个测量,2 个未知量,每个测量都有点噪声。这就是回归问题: $\\\\min \\\\|A\\\\mathbf{x} - \\\\mathbf{b}\\\\|^2$。需要本章末讲的「投影 + 最小二乘」。',
          '**欠定但要稀疏**: 少数测量,要重建高维信号。这就是压缩感知,用到 $L_1$ 正则。会在第 3 章爆发。',
        ]],
        ['p','所以,第 2 章不是「学一个公式」,是「学会区分这五种命运,并在每种命运下找到合适的工具」。这就是为什么本章要花大力气讲: **范数(用什么尺子量误差)、子空间(在哪里找解)、条件数(噪声会被放大多少)、分解(怎么算最快)、正交矩阵(哪种运动最稳)、投影(无解时如何找最近点)**。'],
        ['callout','换句话说: 本章给你的不是「线性代数的内容」,而是**线性代数的诊断地图**——遇到 Ax=b,你能立刻判断它是哪种病、用哪种药。'],

        ['h2','三个让你立刻「看见」矩阵的画面'],
        ['quote','📍 画面一:**橡皮膜变换**。把一张橡皮膜放在桌面上,画一个单位圆。然后用矩阵 $A$ 拉一拉这张膜,圆变成了椭圆。椭圆的最长半轴长度就是 $\\\\|A\\\\|_2$(谱范数);最短半轴是 $1/\\\\|A^{-1}\\\\|_2$;两者的比就是条件数 $\\\\kappa(A)$。这一张画面,就是 2.0 节(范数)和 2.3 节(条件数)的几何全部。'],
        ['quote','📍 画面二:**四个房间**。任意 $m \\\\times n$ 矩阵 $A$ 都把空间分成四个房间:列空间 $C(A) \\\\subseteq \\\\mathbb{R}^m$、零空间 $N(A) \\\\subseteq \\\\mathbb{R}^n$、行空间 $C(A^T) \\\\subseteq \\\\mathbb{R}^n$、左零空间 $N(A^T) \\\\subseteq \\\\mathbb{R}^m$。维数加起来满足 $r + (n-r) = n$ 和 $r + (m-r) = m$。这四个房间就是 2.5 节的「线性代数四大基本子空间」。'],
        ['quote','📍 画面三:**最近点投影**。你站在 3D 空间里,头顶是一面墙(2D 子空间)。「头顶离墙最近的点」就是你头顶在墙上的「正交投影」。投影矩阵 $P = UU^T$($U$ 的列是墙的标准正交基) 把你头顶的位置「压扁」到墙上。这就是 2.6 节的几何全部,也是最小二乘的灵魂。'],

        ['h2','本章逻辑链(你可以反复回到这张图)'],
        ['p','整章可以浓缩成一条主线:'],
        ['p','**第一步: 给「大小」一个尺子(范数)** → **第二步: 给「位置」一个房间(子空间)** → **第三步: 描述「运动」的语法(矩阵 + 基本操作)** → **第四步: 解 Ax=b 的存在性、唯一性、稳定性(条件数)** → **第五步: 算得快(LU / Cholesky / 三对角)** → **第六步: 算得稳(正交矩阵 + 选主元)** → **第七步: 无解时找最近(投影 + 最小二乘)** → **第八步: 矩阵更新时省力(Sherman-Morrison)** → **第九步: 特殊矩阵的特殊待遇(置换 / 傅里叶 / 小波 / 马尔可夫)** → **第十步: 把这些工具用回 AI(线性回归 / 反向传播 / BFGS / PCA)**。'],
        ['callout','所以本章看似「碎」,其实是 10 步串成的一条河。每一步都解决「上一步留下的具体困难」。掌握这条河,胜过孤立背 50 个公式。'],

        ['h2','学习节奏建议(基于认知科学)'],
        ['p','本章干货密度大,**死记硬背一定会忘**。请按下面的节奏来:'],
        ['ol', [
          '**第 1 遍 · 整体地图(60 分钟)**: 只读本章的「intro 文章」+「mindmap」,不要看公式。目标: 在脑子里画出 7 条主分支和它们之间的关系。这是 schema theory(图式理论)的预激活——给后续细节准备好挂钩。',
          '**第 2 遍 · 三篇 deep 文章(每篇 90 分钟)**: 一篇讲范数 + 子空间,一篇讲 Ax=b + 条件数,一篇讲正交 + 投影 + 特殊矩阵。每读完一节,合上书,自己用一句话总结。这是 generation effect。',
          '**第 3 遍 · methods 文章(120 分钟)**: 看 18 个 worked example,每个看之前先暂停 30 秒,试着自己做一遍。这是 pretesting effect——哪怕你做错,也比直接看答案记得久。',
          '**第 4 遍 · 闪卡 + 测验**: 用本工具的 80 张闪卡和 80 道测验做 active recall。每做错一题,在 reflections 里记一笔——这是 desirable difficulty + retrieval practice 的双管齐下。',
          '**考前 1 周 · recap + mindmap**: 只看 recap 文章和 mindmap,不再看 deep。目标: 在大脑里能从 mindmap 任意一个节点说出对应公式 + 应用场景。',
        ]],
        ['p','**总用时**: 大约 14 小时。看起来多,但比你「啃书 30 小时然后忘 80%」高效得多。这是基于 Anki / SuperMemo 几十年的间隔重复研究的合理估计。'],

        ['h2','一个常见的误区: 「我已经学过线性代数了,可以跳过」'],
        ['p','这是研究生最常踩的坑。本科线性代数大多在教**计算技巧**(消元、求逆、行列式、特征值),很少教**结构感**(矩阵作为运动、四大子空间、条件数、投影、伪逆)。你能算 3×3 矩阵的逆,不代表你能在脑子里「看见」一个矩阵在做什么——而 AI 数学需要的恰恰是后者。'],
        ['p','所以即使你成绩很好,也请耐心读完本章的三篇 deep 文章。如果你能在读完后回答下面 5 个问题,那才说明这一关过了:'],
        ['ol', [
